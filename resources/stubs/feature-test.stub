<?php

declare(strict_types=1);

namespace [[ namespace ]];

use Illuminate\Foundation\Testing\RefreshDatabase;

use Tests\TestCase;

/**
 * ==========================================================
 * CENICOM ERP
 * ==========================================================
 *
 * Pruebas funcionales del módulo [[ model ]].
 *
 * @package [[ namespace ]]
 */
final class [[ featureTest ]]
    extends TestCase
{
    use RefreshDatabase;

    public function test_index_page_can_be_displayed(): void
    {
        $response = $this->get(
            route('[[ route ]].index')
        );

        $response->assertOk();
    }

    public function test_create_page_can_be_displayed(): void
    {
        $response = $this->get(
            route('[[ route ]].create')
        );

        $response->assertOk();
    }
}
